<%- include('partials/header', { title: title }) %>

<main>
    <div class="container">
        <h1><%= title %></h1>
        <h2>Assign Categories to: <strong><%= projectDetails.title %></strong></h2>

        <form action="/assign-categories/<%= projectId %>" method="POST" class="assign-categories-form">

            <div class="category-checkboxes">
                <% categories.forEach(category => { %>
                    <div class="checkbox-item">
                        <input
                            type="checkbox"
                            id="category-<%= category.category_id %>"
                            name="categoryIds"
                            value="<%= category.category_id %>"
                            <%= assignedCategories.some(ac => ac.category_id === category.category_id) ? 'checked' : '' %>
                        />
                        <label for="category-<%= category.category_id %>">
                            <%= category.name %>
                        </label>
                    </div>
                <% }); %>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Update Categories</button>
                <a href="/project/<%= projectId %>" class="btn btn-secondary">Cancel</a>
            </div>

        </form>
    </div>
</main>

<%- include('partials/footer') %>