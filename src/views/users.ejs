<%- include('partials/header', { title: title }) %>

<main>
    <div class="container">
        <h1><%= title %></h1>
        <p class="lead">All registered users in the system</p>

        <div class="users-grid">
            <% users.forEach(user => { %>
                <div class="user-card">
                    <h3><%= user.name %></h3>
                    <p class="email"><%= user.email %></p>
                    <span class="role-badge <%= user.role_name %>">
                        <%= user.role_name %>
                    </span>
                </div>
            <% }); %>
        </div>
    </div>
</main>

<%- include('partials/footer') %>