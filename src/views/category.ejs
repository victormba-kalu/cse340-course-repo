<%- include('partials/header', { title: title }) %>

<main>
    <div class="container">
        <a href="/categories" class="back-link">&larr; Back to All Categories</a>
        
        <h1><%= category.name %></h1>
        <p class="lead">Service projects in this category</p>

        <% if (projects && projects.length > 0) { %>
            <div class="projects-list">
                <% projects.forEach(project => { %>
                    <div class="project-item">
                        <a href="/project/<%= project.project_id %>" class="project-link">
                            <%= new Date(project.date).toLocaleDateString('en-US', { 
                                year: 'numeric', 
                                month: 'long', 
                                day: 'numeric' 
                            }) %>: 
                            <strong><%= project.title %></strong>
                        </a>
                        
                        <span class="organization-link">
                            by 
                            <a href="/organization/<%= project.organization_id %>">
                                <%= project.organization_name %>
                            </a>
                        </span>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <p>No projects available in this category yet.</p>
        <% } %>
    </div>
</main>

<%- include('partials/footer') %>