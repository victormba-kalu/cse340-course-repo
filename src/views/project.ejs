<%- include('partials/header', { title: title }) %>

<main>
    <div class="container">
        <a href="/projects" class="back-link">&larr; Back to Upcoming Projects</a>
        
        <div class="project-header">
            <h1><%= project.title %></h1>
            
            <% if (user && user.role_name === 'admin') { %>
                <a href="/edit-project/<%= project.project_id %>" class="btn btn-primary">✏️ Edit Project</a>
            <% } %>
        </div>
        
        <div class="project-meta">
            <p><strong>Date:</strong> <%= new Date(project.date).toLocaleDateString('en-US', { 
                weekday: 'long', 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
            }) %></p>
            <p><strong>Location:</strong> <%= project.location %></p>
        </div>

        <div class="project-description">
            <h2>Description</h2>
            <p><%= project.description %></p>
        </div>

        <!-- Volunteer Section -->
        <% if (isLoggedIn) { %>
        <div class="volunteer-section">
            <h2>Volunteer for this Project</h2>
            
            <% if (isVolunteering) { %>
                <p class="volunteering-status">✅ You are currently volunteering for this project.</p>
                <form action="/project/<%= project.project_id %>/remove-volunteer" method="POST" style="display:inline;">
                    <button type="submit" class="btn btn-danger">Remove Me as Volunteer</button>
                </form>
            <% } else { %>
                <form action="/project/<%= project.project_id %>/volunteer" method="POST" style="display:inline;">
                    <button type="submit" class="btn btn-success">Volunteer for this Project</button>
                </form>
            <% } %>
        </div>
        <% } %>

        <!-- Category Tags -->
        <% if (categories && categories.length > 0) { %>
        <div class="category-tags">
            <h2>Categories</h2>
            <% categories.forEach(category => { %>
                <a href="/category/<%= category.category_id %>" class="category-tag">
                    <%= category.name %>
                </a>
            <% }); %>
        </div>
        <% } %>

        <div class="organization-info">
            <h2>Partner Organization</h2>
            <p>
                This project is sponsored by: 
                <a href="/organization/<%= project.organization_id %>">
                    <strong><%= project.organization_name %></strong>
                </a>
            </p>
        </div>
    </div>
</main>

<%- include('partials/footer') %>